// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core subworkflows test cellprofiler_load_data_csv
nextflow_workflow {

    name "Test Subworkflow CELLPROFILER_LOAD_DATA_CSV"
    script "../main.nf"
    workflow "CELLPROFILER_LOAD_DATA_CSV"

    tag "subworkflows/cellprofiler_load_data_csv"

    setup {
        run("PIPELINE_INITIALISATION") {
            script "../../utils_nfcore_cellpainting_pipeline/main.nf"
            workflow {
                """
                input[0] = false // version
                input[1] = false // validate_params
                input[2] = false // monochrome_logs
                input[3] = "   " // nextflow_cli_args
                input[4] = "results"
                input[5] = "${projectDir}/assets/samplesheet.csv"
                """
            }
        }
    }

    test("group_by_batch_plate_channel") {

        when {
            workflow {
                """
                input[0] = PIPELINE_INITIALISATION.out.samplesheet
                input[1] = ['batch', 'plate', 'channel']
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success},
                { assert snapshot(workflow.out).match()},
                { 
                    // Check each CSV has the correct single-channel header
                    workflow.out.images_with_load_data_csv.each { meta, images, csv_file -> 
                        def csv_lines = path(csv_file).readLines()
                        def header = csv_lines[0]
                        def expected_header = "FileName_Orig${meta.channel},Metadata_Batch,Metadata_Plate,Metadata_Well,Metadata_Col,Metadata_Row,Metadata_Site"
                        assert header == expected_header : "Expected: $expected_header, but got: $header"
                    }
                }
            )
        }
    }

    test("group_by_batch_plate") {

        when {
            workflow {
                """
                input[0] = PIPELINE_INITIALISATION.out.samplesheet
                input[1] = ['batch', 'plate']
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success},
                { assert snapshot(workflow.out).match()},
                {
                    // Check each CSV has the correct multi-channel header
                    workflow.out.images_with_load_data_csv.each { meta, images, csv_file -> 
                        def csv_lines = path(csv_file).readLines()
                        def header = csv_lines[0]
                        def expected_header = "FileName_OrigAGP,FileName_OrigBrightfield,FileName_OrigBrightfield_H,FileName_OrigBrightfield_L,FileName_OrigDNA,FileName_OrigER,FileName_OrigMito,FileName_OrigRNA,Metadata_Batch,Metadata_Plate,Metadata_Well,Metadata_Col,Metadata_Row,Metadata_Site"
                        assert header == expected_header : "Expected: $expected_header, but got: $header"
                    }
                }
            )
        }
    }
}
