nextflow_process {

    name "Test Process PYCYTOMINER_ANNOTATE"
    script "modules/local/pycytominer/annotate/main.nf"
    process "PYCYTOMINER_ANNOTATE"

    tag "modules"
    tag "modules_"
    tag "pycytominer"
    tag "pycytominer/annotate"

    test(" annotate - parquet ") {
        when {
            process {
                """
                // define inputs of the process here. Example:
                input[0] = file("/Users/franz/Hackaton_Netxflow/datas/cleaned_scProfiles/BR00117035.parquet")
                input[1] = file("/Users/franz/Hackaton_Netxflow/datas/metadatas/BR00117035.txt")
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }

    test(" annotate - parquet - stub") {
        options "-stub"

        when {
            process {
                """
                // define inputs of the process here. Example:
                input[0] = file("s3://cellpainting-gallery/cpg0016-jump/source_4/workspace/profiles/2021_04_26_Batch1/BR00117035/BR00117035.parquet", checkIfExists: true)
                input[1] = file("https://data.cyverse.org/dav-anon/iplant/home/franzx5/Hackaton_nf/BR00117035.txt", checkIfExists: true)
                """
            }
        }
        
        then {
            assert process.success
            assert snapshot(process.out).match()
        }
    }



}
