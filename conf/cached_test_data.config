/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running nf-test against a locally cached mirror of the
    Cell Painting Gallery test data
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~

    Use as follows:
        nf-test test ... --profile test,docker,cached_test_data

    Stage the mirror first (see AGENTS.md/CLAUDE.md for the `aws s3 sync` commands).
----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Cached Cell Painting Gallery test data profile'
    config_profile_description = 'Resolve test fixtures from a local mirror under .nf-test/testdata/ instead of S3'

    cellpainting_gallery_testdata_base_path = "${projectDir}/.nf-test/testdata/"
}
