nextflow_process {
    name "Test Process CELLPROFILER_ANALYSIS"
    script "../../analysis.nf"
    process "CELLPROFILER_ANALYSIS"
    tag "cellprofiler"
    tag "cellprofiler/analysis"

    test("cellprofiler - analysis") {
        when {
            process {
                """
                def images_meta = [
                    [filename:'r01c01f01p01-ch5sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'DNA'],
                    [filename:'r01c01f01p01-ch2sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'AGP'],
                    [filename:'r01c01f01p01-ch3sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'RNA'],
                    [filename:'r01c01f01p01-ch4sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'ER'],
                    [filename:'r01c01f01p01-ch1sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Mito'],
                    [filename:'r01c01f01p01-ch8sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield'],
                    [filename:'r01c01f01p01-ch6sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield_H'],
                    [filename:'r01c01f01p01-ch7sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield_L'],
                ]
                def imagePrefix = 'cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/'
                def illumPrefix = 'cpg0016-jump/source_4/images/2021_04_26_Batch1/illum/BR00117035/'
                input[0] = [
                    [id:"2021_04_26_Batch1_BR00117035_A01_1", batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', site:1],
                    images_meta,
                    [
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch5sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch2sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch3sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch4sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch1sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch8sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch6sk1fk1fl1.tiff', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + imagePrefix + 'r01c01f01p01-ch7sk1fk1fl1.tiff', checkIfExists: true),
                    ],
                    [
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumDNA.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumAGP.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumRNA.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumER.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumMito.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumBrightfield.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumBrightfield_H.npy', checkIfExists: true),
                        file(params.cellpainting_gallery_testdata_base_path + illumPrefix + 'BR00117035_IllumBrightfield_L.npy', checkIfExists: true),
                    ]
                ]
                input[1] = file("${projectDir}/assets/cellprofiler/analysis.cppipe", checkIfExists: true)
                """
            }
        }
        then {
            // Files excluded from the snapshot:
            //   - Image.csv, Experiment.csv: embed non-deterministic values (work-dir
            //     absolute paths in PathName_*Outlines, Run_Timestamp). See #38.
            //   - Cells.csv, Cytoplasm.csv, Nuclei.csv: per-cell measurements drift
            //     across BLAS implementations (macOS Accelerate vs Linux OpenBLAS),
            //     so md5 snapshots cannot match cross-platform. These three files are
            //     covered separately by the schema/row-count/area-mean assertions
            //     below. See #41.
            def stable_files = getAllFilesFromDir(
                process.out.output_dir[0][1].toString(),
                ignore: [
                    'Image.csv', 'Experiment.csv',
                    'Cells.csv', 'Cytoplasm.csv', 'Nuclei.csv',
                    '**/Image.csv', '**/Experiment.csv',
                    '**/Cells.csv', '**/Cytoplasm.csv', '**/Nuclei.csv'
                ]
            )

            // Content-aware assertions for the BLAS-sensitive per-cell measurement CSVs.
            // Expected values were captured from a verified Linux Docker run; see #41.
            def parseCsv = { p ->
                def lines = file(p).readLines()
                [header: lines[0].split(',') as List,
                 rows:   lines[1..-1].collect { it.split(',', -1) as List }]
            }
            def meanOf = { csv, col ->
                def i = csv.header.indexOf(col)
                csv.rows.collect { (it[i] as Double) }.sum() / csv.rows.size()
            }
            def withinPct = { actual, expected, pct ->
                Math.abs(actual - expected) / expected < pct
            }
            def expectedHeader = { name ->
                file("${projectDir}/modules/local/cellprofiler/analysis/tests/expected_headers/${name}.txt").text.trim().split(',') as List
            }

            def analysisDir = process.out.output_dir[0][1].toString()
            def cells = parseCsv("${analysisDir}/Cells.csv")
            def cytoplasm = parseCsv("${analysisDir}/Cytoplasm.csv")
            def nuclei = parseCsv("${analysisDir}/Nuclei.csv")

            assertAll(
                { assert process.success },
                { assert snapshot(stable_files, process.out.versions).match() },

                { assert cells.header == expectedHeader('Cells') },
                { assert cells.rows.size() == 66 },
                { assert withinPct(meanOf(cells, 'AreaShape_Area'), 6668.818181818182, 0.01) },

                { assert cytoplasm.header == expectedHeader('Cytoplasm') },
                { assert cytoplasm.rows.size() == 66 },
                { assert withinPct(meanOf(cytoplasm, 'AreaShape_Area'), 5689.833333333333, 0.01) },

                { assert nuclei.header == expectedHeader('Nuclei') },
                { assert nuclei.rows.size() == 66 },
                { assert withinPct(meanOf(nuclei, 'AreaShape_Area'), 1134.8636363636363, 0.01) },
            )
        }
    }

    test("cellprofiler - analysis - stub") {
        tag "stub"
        options "-stub"
        when {
            process {
                """
                def images_meta = [
                    [filename:'r01c01f01p01-ch1sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'DNA'],
                    [filename:'r01c01f01p01-ch2sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'AGP'],
                    [filename:'r01c01f01p01-ch3sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'RNA'],
                    [filename:'r01c01f01p01-ch4sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'ER'],
                    [filename:'r01c01f01p01-ch5sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Mito'],
                    [filename:'r01c01f01p01-ch6sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield'],
                    [filename:'r01c01f01p01-ch7sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield_H'],
                    [filename:'r01c01f01p01-ch8sk1fk1fl1.tiff', batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', col:1, row:1, site:1, channel:'Brightfield_L'],
                ]
                input[0] = [
                    [id:"2021_04_26_Batch1_BR00117035_A01_1", batch:'2021_04_26_Batch1', plate:'BR00117035', well:'A01', site:1],
                    images_meta,
                    [
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch1sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch2sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch3sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch4sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch5sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch6sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch7sk1fk1fl1.tiff"),
                        file("s3://cellpainting-gallery/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/r01c01f01p01-ch8sk1fk1fl1.tiff"),
                    ],
                    [
                        file("dummy_illum_DNA.npy"),
                        file("dummy_illum_AGP.npy"),
                        file("dummy_illum_RNA.npy"),
                        file("dummy_illum_ER.npy"),
                        file("dummy_illum_Mito.npy"),
                        file("dummy_illum_Brightfield.npy"),
                        file("dummy_illum_Brightfield_H.npy"),
                        file("dummy_illum_Brightfield_L.npy"),
                    ]
                ]
                input[1] = file("${projectDir}/assets/cellprofiler/analysis.cppipe", checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
