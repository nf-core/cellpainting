// TODO nf-core: Once you have added the required tests, please run the following command to build this file:
// nf-core modules test cellprofiler/illuminationcorrection
nextflow_process {

    name "Test Process CELLPROFILER_ILLUMINATIONCORRECTION"
    script "../main.nf"
    process "CELLPROFILER_ILLUMINATIONCORRECTION"

    tag "cellprofiler"
    tag "cellprofiler/illuminationcorrection"

    test("cellprofiler corrects illumination") {

        when {
            process {
                """
                input[0] = [
                    [ id:'BR00117035' ], // meta map
                    file('https://raw.githubusercontent.com/gerbeldo/cellpainting/refs/heads/illumination-correction/modules/local/cellprofiler/illuminationcorrection/tests/testdata/load_data.csv', checkIfExists: true),
                ]
                input[1] = file(params.modules_testdata_base_path + 'minimal_dataset/cpg0016-jump/source_4/images/2021_04_26_Batch1/images/BR00117035__2021-05-02T16_02_51-Measurement1/Images/', checkIfExists: true)
                input[2] = file(params.modules_testdata_base_path + 'minimal_dataset/cpg0016-jump/source_4/workspace/pipelines/2021_04_26_Batch1/illum.cppipe', checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }

    }

    // TODO nf-core: Change the test name preferably indicating the test-data and file-format used but keep the " - stub" suffix.
